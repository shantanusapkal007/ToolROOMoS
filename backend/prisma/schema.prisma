generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String
  name           String
  role           SystemRole    @default(PRODUCTION)
  isActive       Boolean       @default(true)
  employeeId     String?       @unique
  hourlyRate     Decimal       @default(0)
  status         String        @default("ACTIVE")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lastLoginAt    DateTime?
  plantId        String?
  primaryPlantId String?
  employee       Employee?     @relation(fields: [employeeId], references: [id])
  plants         Plant?        @relation("UserPlants", fields: [plantId], references: [id])
  primaryPlant   Plant?        @relation("UserPrimaryPlant", fields: [primaryPlantId], references: [id])
  projectTeams   ProjectTeam[]

  @@map("users")
}

model Company {
  id           String     @id @default(uuid())
  companyCode  String     @unique
  companyName  String
  gstNumber    String?
  pan          String?
  address      String?
  contactPhone String?
  contactEmail String?
  currency     String     @default("INR")
  status       String     @default("ACTIVE")
  remarks      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String?
  updatedBy    String?
  customers    Customer[]
  plants       Plant[]
  vendors      Vendor[]

  @@map("companies")
}

model Plant {
  id           String       @id @default(uuid())
  plantCode    String       @unique
  plantName    String
  address      String?
  workingHours String?
  companyId    String
  status       String       @default("ACTIVE")
  remarks      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  createdBy    String?
  updatedBy    String?
  departments  Department[]
  machines     Machine[]
  company      Company      @relation(fields: [companyId], references: [id])
  projects     Project[]
  users        User[]       @relation("UserPlants")
  primaryUsers User[]       @relation("UserPrimaryPlant")
  warehouses   Warehouse[]

  @@map("plants")
}

model Department {
  id             String     @id @default(uuid())
  departmentCode String     @unique
  departmentName String
  plantId        String
  status         String     @default("ACTIVE")
  remarks        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  createdBy      String?
  updatedBy      String?
  plant          Plant      @relation(fields: [plantId], references: [id])
  employees      Employee[]
  machines       Machine[]

  @@map("departments")
}

model Customer {
  id              String         @id @default(uuid())
  customerCode    String         @unique
  companyName     String
  gstNumber       String?
  billingAddress  String?
  shippingAddress String?
  contactPerson   String?
  contactPhone    String?
  contactEmail    String?
  paymentTerms    String?
  companyId       String
  status          String         @default("ACTIVE")
  remarks         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?
  updatedBy       String?
  company         Company        @relation(fields: [companyId], references: [id])
  dispatchNotes   DispatchNote[]
  projects        Project[]

  @@map("customers")
}

model Vendor {
  id                   String                @id @default(uuid())
  vendorCode           String                @unique
  vendorName           String
  vendorType           VendorType
  gstNumber            String?
  address              String?
  contactPhone         String?
  contactEmail         String?
  companyId            String
  status               String                @default("ACTIVE")
  remarks              String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  createdBy            String?
  updatedBy            String?
  purchaseOrderHeaders PurchaseOrderHeader[]
  subcontractOrders    SubcontractOrder[]
  company              Company               @relation(fields: [companyId], references: [id])
  vendorBills          VendorBill[]

  @@map("vendors")
}

model Material {
  id                          String                       @id @default(uuid())
  materialCode                String                       @unique
  materialGrade               String
  materialCategory            String?
  density                     Decimal?
  standardCost                Decimal                      @default(0)
  defaultUom                  String
  defaultVendor               String?
  shapeId                     String?
  status                      String                       @default("ACTIVE")
  remarks                     String?
  hsnCode                     String?
  gstPercent                  Decimal?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  createdBy                   String?
  updatedBy                   String?
  billOfMaterialItems         BillOfMaterialItem[]
  inventoryBatches            InventoryBatch[]
  inventoryStock              InventoryStock[]
  materialRequirements        MaterialRequirement[]
  planningExceptions          PlanningException[]
  planningRecommendationItems PlanningRecommendationItem[]
  shape                       MaterialShape?               @relation(fields: [shapeId], references: [id])
  purchaseOrderItems          PurchaseOrderItem[]

  wipLedgers           WipLedger[]
  purchaseRequestItems PurchaseRequestItem[]
  vendorBillItems      VendorBillItem[]
  assemblyComponents   AssemblyComponent[]

  @@map("materials")
}

model MaterialShape {
  id        String     @id @default(uuid())
  shapeName String     @unique
  status    String     @default("ACTIVE")
  remarks   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdBy String?
  updatedBy String?
  materials Material[]

  @@map("material_shapes")
}

model Machine {
  id                   String                   @id @default(uuid())
  machineCode          String                   @unique
  machineName          String
  machineType          String
  hourlyRate           Decimal                  @default(0)
  capacity             String?
  plantId              String
  departmentId         String
  status               String                   @default("ACTIVE")
  remarks              String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  createdBy            String?
  updatedBy            String?
  jobCards             JobCard[]
  machineShopReports   MachineShopDailyReport[]
  department           Department               @relation(fields: [departmentId], references: [id])
  plant                Plant                    @relation(fields: [plantId], references: [id])
  productionOperations ProductionOperation[]
  routingOperations    RoutingOperation[]

  wipLedgers          WipLedger[]
  machineCalendars    MachineCalendar[]
  productionSchedules ProductionSchedule[]
  oeeDailyLogs        OeeDailyLog[]

  isActive    Boolean      @default(true)
  msdrHeaders MsdrHeader[]

  @@map("machines")
}

model Operation {
  id                    String                 @id @default(uuid())
  operationCode         String                 @unique
  operationName         String
  status                String                 @default("ACTIVE")
  remarks               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  createdBy             String?
  updatedBy             String?
  routingOperations     RoutingOperation[]
  subcontractOrderItems SubcontractOrderItem[]
  msdrOperations        MsdrOperation[]

  @@map("operations")
}

model Tool {
  id        String   @id @default(uuid())
  toolCode  String   @unique
  toolName  String
  toolType  String?
  toolLife  String?
  cost      Decimal  @default(0)
  status    String   @default("ACTIVE")
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@map("tools")
}

model Employee {
  id                   String                   @id @default(uuid())
  employeeCode         String                   @unique
  name                 String
  designation          String?
  hourlyRate           Decimal                  @default(0)
  shiftId              String?
  departmentId         String
  status               String                   @default("ACTIVE")
  remarks              String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  createdBy            String?
  updatedBy            String?
  employeeType         EmployeeType             @default(INTERNAL)
  department           Department               @relation(fields: [departmentId], references: [id])
  shift                Shift?                   @relation(fields: [shiftId], references: [id])
  jobCards             JobCard[]
  machineShopReports   MachineShopDailyReport[]
  productionOperations ProductionOperation[]
  user                 User?
  msdrHeaders          MsdrHeader[]

  @@map("employees")
}

model Shift {
  id        String     @id @default(uuid())
  shiftName String     @unique
  startTime String
  endTime   String
  status    String     @default("ACTIVE")
  remarks   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdBy String?
  updatedBy String?
  employees Employee[]

  machineCalendars MachineCalendar[]

  @@map("shifts")
}

model Warehouse {
  id             String            @id @default(uuid())
  warehouseCode  String            @unique
  warehouseName  String
  warehouseType  String?
  plantId        String
  status         String            @default("ACTIVE")
  remarks        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      String?
  updatedBy      String?
  inventoryStock InventoryStock[]
  locations      StorageLocation[]
  plant          Plant             @relation(fields: [plantId], references: [id])

  @@map("warehouses")
}

model StorageLocation {
  id               String           @id @default(uuid())
  locationCode     String           @unique
  locationName     String
  warehouseId      String
  status           String           @default("ACTIVE")
  remarks          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdBy        String?
  updatedBy        String?
  inventoryBatches InventoryBatch[]
  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id])

  @@map("storage_locations")
}

model Uom {
  id        String   @id @default(uuid())
  uomCode   String   @unique
  uomName   String
  status    String   @default("ACTIVE")
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@map("uoms")
}

model InspectionStandard {
  id                     String                  @id @default(uuid())
  standardCode           String                  @unique
  standardName           String
  description            String?
  status                 String                  @default("ACTIVE")
  remarks                String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  createdBy              String?
  updatedBy              String?
  inspectionMeasurements InspectionMeasurement[]

  @@map("inspection_standards")
}

model CostRate {
  id        String   @id @default(uuid())
  rateType  String
  rateName  String
  rateValue Decimal
  status    String   @default("ACTIVE")
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@map("cost_rates")
}

model DocumentType {
  id               String            @id @default(uuid())
  typeCode         String            @unique
  typeName         String
  status           String            @default("ACTIVE")
  remarks          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String?
  updatedBy        String?
  projectDocuments ProjectDocument[]

  @@map("document_types")
}

model Project {
  id                    String                   @id @default(uuid())
  projectNumber         String                   @unique
  customerPoNumber      String?
  partName              String
  description           String?
  targetDeliveryDate    DateTime?
  actualDeliveryDate    DateTime?
  currentStage          ProjectStatus            @default(CREATED)
  priority              String                   @default("NORMAL")
  progress              Decimal                  @default(0)
  projectOwner          String?
  customerId            String
  plantId               String
  status                String                   @default("ACTIVE")
  remarks               String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  createdBy             String?
  updatedBy             String?
  closedAt              DateTime?
  approvals             Approval[]
  billOfMaterialHeaders BillOfMaterialHeader[]
  dispatchNotes         DispatchNote[]
  goodsReceiptHeaders   GoodsReceiptHeader[]
  inspectionHeaders     InspectionHeader[]
  inventoryReservations InventoryReservation[]
  inventoryTransactions InventoryTransaction[]
  invoiceHeaders        InvoiceHeader[]
  jobCards              JobCard[]
  machineShopReports    MachineShopDailyReport[]
  materialIssueHeaders  MaterialIssueHeader[]
  materialRequirements  MaterialRequirement[]
  ncrReports            NcrReport[]
  planningRuns          PlanningRun[]
  productionBatches     ProductionBatch[]
  projectActivities     ProjectActivity[]
  projectCostEvents     ProjectCostEvent[]
  projectCostSummary    ProjectCostSummary?
  projectDocuments      ProjectDocument[]
  projectTasks          ProjectTask[]
  projectTimeline       ProjectTimeline[]
  customer              Customer                 @relation(fields: [customerId], references: [id])
  plant                 Plant                    @relation(fields: [plantId], references: [id])
  purchaseOrderHeaders  PurchaseOrderHeader[]
  routingHeaders        RoutingHeader[]
  subcontractOrders     SubcontractOrder[]
  subcontractReceipts   SubcontractReceipt[]

  wipLedgers             WipLedger[]
  productionSchedules    ProductionSchedule[]
  purchaseRequestHeaders PurchaseRequestHeader[]
  projectBudget          ProjectBudget?
  projectTeams           ProjectTeam[]
  accountEntries         AccountEntry[]
  assemblyHeaders        AssemblyHeader[]

  @@map("projects")
}

model ProjectDocument {
  id             String             @id @default(uuid())
  projectId      String
  documentTypeId String
  documentNumber String?
  fileName       String
  fileUrl        String
  revision       Int                @default(1)
  status         DocumentStatus     @default(DRAFT)
  remarks        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?
  updatedBy      String?
  revisions      DocumentRevision[]
  documentType   DocumentType       @relation(fields: [documentTypeId], references: [id])
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_documents")
}

model DocumentRevision {
  id                String          @id @default(uuid())
  projectDocumentId String
  revisionNumber    Int
  fileUrl           String
  changeDescription String?
  remarks           String?
  createdAt         DateTime        @default(now())
  createdBy         String?
  projectDocument   ProjectDocument @relation(fields: [projectDocumentId], references: [id])

  @@map("document_revisions")
}

model BillOfMaterialHeader {
  id                 String               @id @default(uuid())
  projectId          String
  documentNumber     String?
  revision           Int                  @default(1)
  status             DocumentStatus       @default(DRAFT)
  approvalStatus     ApprovalStatus       @default(PENDING)
  totalEstimatedCost Decimal              @default(0)
  remarks            String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  createdBy          String?
  updatedBy          String?
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items              BillOfMaterialItem[]

  @@map("bill_of_material_headers")
}

model BillOfMaterialItem {
  id               String   @id @default(uuid())
  bomHeaderId      String
  materialId       String
  rawSize          String?
  dimensions       String?
  hsnCode          String?
  calculatedWeight Decimal?
  requiredQty      Decimal
  estimatedCost    Decimal  @default(0)
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdBy        String?
  updatedBy        String?
  isAssembly       Boolean  @default(false)
  customFields     Json?

  parentItemId String?
  parentItem   BillOfMaterialItem?  @relation("BomItemHierarchy", fields: [parentItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childItems   BillOfMaterialItem[] @relation("BomItemHierarchy")

  bomHeader BillOfMaterialHeader @relation(fields: [bomHeaderId], references: [id], onDelete: Cascade)
  material  Material             @relation(fields: [materialId], references: [id])

  @@map("bill_of_material_items")
}

model RoutingHeader {
  id             String             @id @default(uuid())
  projectId      String
  documentNumber String?
  revision       Int                @default(1)
  status         DocumentStatus     @default(DRAFT)
  approvalStatus ApprovalStatus     @default(PENDING)
  remarks        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?
  updatedBy      String?
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  operations     RoutingOperation[]

  @@map("routing_headers")
}

model RoutingOperation {
  id                      String                   @id @default(uuid())
  routingHeaderId         String
  sequenceOrder           Int
  operationId             String
  estimatedHours          Decimal                  @default(0)
  remarks                 String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdBy               String?
  updatedBy               String?
  completedQuantity       Decimal                  @default(0)
  estimatedSetupTime      Decimal                  @default(0)
  plannedMachineId        String?
  remainingQuantity       Decimal                  @default(0)
  status                  String                   @default("PENDING")
  inspections             InspectionHeader[]
  jobCards                JobCard[]
  machineShopDailyReports MachineShopDailyReport[]
  productionOperations    ProductionOperation[]
  operation               Operation                @relation(fields: [operationId], references: [id])
  plannedMachine          Machine?                 @relation(fields: [plannedMachineId], references: [id])
  routingHeader           RoutingHeader            @relation(fields: [routingHeaderId], references: [id])

  wipLedgers WipLedger[]

  @@map("routing_operations")
}

model MaterialRequirement {
  id           String    @id @default(uuid())
  projectId    String
  materialId   String
  requiredQty  Decimal
  requiredDate DateTime?
  status       String    @default("OPEN")
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  material     Material  @relation(fields: [materialId], references: [id])
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("material_requirements")
}

model PurchaseOrderHeader {
  purchaseRequestId String?
  id                   String               @id @default(uuid())
  projectId            String
  vendorId             String
  poNumber             String               @unique
  documentNumber       String?
  revision             Int                  @default(1)
  totalAmount          Decimal              @default(0)
  expectedDeliveryDate DateTime?
  status               PurchaseOrderStatus  @default(DRAFT)
  approvalStatus       ApprovalStatus       @default(PENDING)
  remarks              String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  createdBy            String?
  updatedBy            String?
  goodsReceiptHeaders  GoodsReceiptHeader[]
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor               Vendor               @relation(fields: [vendorId], references: [id])
  items                PurchaseOrderItem[]

  deliveryDate DateTime?

  vendorGstNumber String?

  costCentre  String?
  vendorBills VendorBill[]

  gstPercent Decimal?

  hsnCode String?

  @@map("purchase_order_headers")
}

model PurchaseOrderItem {
  id                String              @id @default(uuid())
  poHeaderId        String
  materialId        String
  orderedQty        Decimal
  agreedRate        Decimal
  lineTotal         Decimal             @default(0)
  remarks           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String?
  updatedBy         String?
  receivedQty       Decimal             @default(0)
  status            String              @default("PENDING")
  goodsReceiptItems GoodsReceiptItem[]
  material          Material            @relation(fields: [materialId], references: [id])
  poHeader          PurchaseOrderHeader @relation(fields: [poHeaderId], references: [id])

  dimensions String?

  gstPercent Decimal?

  hsnCode String?

  @@map("purchase_order_items")
}

model GoodsReceiptHeader {
  id             String              @id @default(uuid())
  projectId      String
  poHeaderId     String
  grnNumber      String              @unique
  documentNumber String?
  receiptDate    DateTime            @default(now())
  status         String              @default("COMPLETED")
  remarks        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String?
  updatedBy      String?
  poHeader       PurchaseOrderHeader @relation(fields: [poHeaderId], references: [id])
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items          GoodsReceiptItem[]

  vendorInvoiceNumber String?

  invoiceDate  DateTime?
  customFields Json?

  @@map("goods_receipt_headers")
}

model GoodsReceiptItem {
  id                 String             @id @default(uuid())
  grnHeaderId        String
  poItemId           String
  receivedQty        Decimal
  acceptedQty        Decimal
  rejectedQty        Decimal            @default(0)
  heatNumber         String?
  actualRate         Decimal
  actualMaterialCost Decimal            @default(0)
  remarks            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdBy          String?
  updatedBy          String?
  grnHeader          GoodsReceiptHeader @relation(fields: [grnHeaderId], references: [id])
  poItem             PurchaseOrderItem  @relation(fields: [poItemId], references: [id])
  inventoryBatches   InventoryBatch[]

  batchNumber String?

  hsnCode     String?
  warehouseId String?

  gstPercent Decimal?

  rackLocation String?

  @@map("goods_receipt_items")
}

model MaterialIssueHeader {
  id                      String                   @id @default(uuid())
  projectId               String
  issueNumber             String                   @unique
  documentNumber          String?
  issueDate               DateTime                 @default(now())
  status                  String                   @default("COMPLETED")
  remarks                 String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdBy               String?
  updatedBy               String?
  machineShopDailyReports MachineShopDailyReport[]
  project                 Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items                   MaterialIssueItem[]

  @@map("material_issue_headers")
}

model MaterialIssueItem {
  id               String              @id @default(uuid())
  issueHeaderId    String
  inventoryBatchId String
  issuedQty        Decimal
  materialValue    Decimal             @default(0)
  remarks          String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  createdBy        String?
  updatedBy        String?
  inventoryBatch   InventoryBatch      @relation(fields: [inventoryBatchId], references: [id])
  issueHeader      MaterialIssueHeader @relation(fields: [issueHeaderId], references: [id])

  @@index([issueHeaderId])
  @@index([inventoryBatchId])
  @@map("material_issue_items")
}

model InspectionHeader {
  id                    String                  @id @default(uuid())
  projectId             String
  productionOperationId String?
  inspectionNumber      String                  @unique
  documentNumber        String?
  inspectedQty          Decimal
  passedQty             Decimal                 @default(0)
  reworkQty             Decimal                 @default(0)
  scrapQty              Decimal                 @default(0)
  result                InspectionResult        @default(PASS)
  status                String                  @default("COMPLETED")
  remarks               String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  createdBy             String?
  updatedBy             String?
  inspectionType        InspectionType          @default(IN_PROCESS)
  routingOperationId    String?
  project               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  routingOperation      RoutingOperation?       @relation(fields: [routingOperationId], references: [id])
  measurements          InspectionMeasurement[]

  @@map("inspection_headers")
}

model InspectionMeasurement {
  id                   String             @id @default(uuid())
  inspectionHeaderId   String
  inspectionStandardId String
  nominalValue         Decimal
  upperTolerance       Decimal?
  lowerTolerance       Decimal?
  actualValue          Decimal
  result               InspectionResult
  remarks              String?
  createdAt            DateTime           @default(now())
  createdBy            String?
  inspectionHeader     InspectionHeader   @relation(fields: [inspectionHeaderId], references: [id])
  inspectionStandard   InspectionStandard @relation(fields: [inspectionStandardId], references: [id])

  @@map("inspection_measurements")
}

model NcrReport {
  id                String   @id @default(uuid())
  projectId         String
  ncrNumber         String   @unique
  defectDescription String
  rootCause         String?
  disposition       String?
  status            String   @default("OPEN")
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  updatedBy         String?
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ncr_reports")
}

model DispatchNote {
  id                 String          @id @default(uuid())
  projectId          String
  customerId         String
  dispatchNumber     String          @unique
  documentNumber     String?
  dispatchDate       DateTime        @default(now())
  dispatchQty        Decimal
  transporterName    String?
  transporterDetails String?
  vehicleNumber      String?
  logisticsCost      Decimal         @default(0)
  status             String          @default("COMPLETED")
  remarks            String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdBy          String?
  updatedBy          String?
  driverDetails      String?
  trackingReference  String?
  items              DispatchItem[]
  customer           Customer        @relation(fields: [customerId], references: [id])
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceHeaders     InvoiceHeader[]

  @@map("dispatch_notes")
}

model DispatchItem {
  id              String       @id @default(uuid())
  dispatchNoteId  String
  partDescription String
  quantity        Decimal
  remarks         String?
  createdAt       DateTime     @default(now())
  createdBy       String?
  dispatchNote    DispatchNote @relation(fields: [dispatchNoteId], references: [id])

  @@map("dispatch_items")
}

model InvoiceHeader {
  id             String           @id @default(uuid())
  projectId      String
  dispatchNoteId String
  invoiceNumber  String           @unique
  documentNumber String?
  invoiceDate    DateTime         @default(now())
  subtotal       Decimal          @default(0)
  taxAmount      Decimal          @default(0)
  totalAmount    Decimal          @default(0)
  status         String           @default("GENERATED")
  remarks        String?
  createdAt      DateTime         @default(now())
