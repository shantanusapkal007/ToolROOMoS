  operatorId      String?
  jobCard         JobCard   @relation(fields: [jobCardId], references: [id])

  status   String   @default("ACTIVE")
  duration Decimal?

  @@map("job_card_time_logs")
}

model ProjectBudget {
  id            String  @id @default(uuid())
  projectId     String  @unique
  estimatedCost Decimal @default(0)
  actualCost    Decimal @default(0)
  project       Project @relation(fields: [projectId], references: [id])

  @@map("project_budgets")
}

model ProjectTeam {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  role      String
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@map("project_teams")
}

model AccountEntry {
  id          String   @id @default(uuid())
  projectId   String
  type        String
  amount      Decimal
  referenceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])

  entryDate DateTime?

  entryType String?

  category String?

  referenceDocType String?

  @@map("account_entries")
}

model AssemblyHeader {
  id             String              @id @default(uuid())
  projectId      String
  assemblyNumber String              @unique
  status         String              @default("DRAFT")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  project        Project             @relation(fields: [projectId], references: [id])
  components     AssemblyComponent[]

  assemblyName String?

  @@map("assembly_headers")
}

model AssemblyComponent {
  id               String         @id @default(uuid())
  assemblyHeaderId String
  materialId       String
  quantity         Decimal
  assemblyHeader   AssemblyHeader @relation(fields: [assemblyHeaderId], references: [id])
  material         Material       @relation(fields: [materialId], references: [id])

  @@map("assembly_components")
}

model Comment {
  id           String   @id @default(uuid())
  documentId   String
  documentType String
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  @@map("comments")
}

model DocumentLink {
  id           String   @id @default(uuid())
  sourceId     String
  sourceType   String
  targetId     String
  targetType   String
  relationType String   @default("REFERENCE")
  createdAt    DateTime @default(now())

  sourceEntityType String?
  targetEntityType String?

  @@map("document_links")
}

model DocumentRegistry {
  id             String   @id @default(uuid())
  documentNumber String   @unique
  documentType   String
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy String?

  @@map("document_registries")
}

model ImportExportJob {
  id               String   @id @default(uuid())
  jobType          String
  status           String   @default("PENDING")
  totalRecords     Int      @default(0)
  processedRecords Int      @default(0)
  failedRecords    Int      @default(0)
  errors           Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entityType   String?
  processedRow Int     @default(0)

  @@map("import_export_jobs")
}

model NotificationTemplate {
  id           String   @id @default(uuid())
  templateCode String   @unique
  subject      String
  body         String
  createdAt    DateTime @default(now())

  templateKey String? @unique

  @@map("notification_templates")
}

model NotificationLog {
  id           String   @id @default(uuid())
  userId       String
  templateCode String
  status       String   @default("SENT")
  createdAt    DateTime @default(now())

  templateKey String?

  @@map("notification_logs")
}

model DocumentSequence {
  id            String   @id @default(uuid())
  documentType  String   @unique
  prefix        String
  currentNumber Int      @default(0)
  padding       Int      @default(4)
  suffix        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  nextNumber Int @default(1)

  zeroPadding   Boolean @default(true)
  financialYear String?

  @@map("document_sequences")
}

model SystemSetting {
  id           String   @id @default(uuid())
  settingKey   String   @unique
  settingValue Json
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plantId   String?
  updatedBy String?

  @@unique([plantId, settingKey])
  @@map("system_settings")
}

model WorkflowInstance {
  id           String                 @id @default(uuid())
  workflowId   String
  documentId   String
  documentType String
  status       String                 @default("IN_PROGRESS")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  steps        WorkflowStepInstance[]

  workflowName String?
  completedAt  DateTime?

  entityType String?

  @@map("workflow_instances")
}

model WorkflowStepInstance {
  id                 String           @id @default(uuid())
  workflowInstanceId String
  stepName           String
  status             String           @default("PENDING")
  approverId         String?
  comments           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id])

  stepOrder    Int       @default(0)
  errorPayload Json?
  completedAt  DateTime?
  startedAt    DateTime?

  @@map("workflow_step_instances")
}

